    main_interface = widgets.VBox(
        interface_children,
        layout=widgets.Layout(width="100%")
    )

except Exception as exc:

    print("Unable to assemble interface:")
    print(exc)

# ------------------------------------------------------------------
# Display only one interface.
# ------------------------------------------------------------------

try:

    from IPython.display import clear_output

    clear_output(wait=True)

    display(main_interface)

    if IPYALADIN_AVAILABLE:
        viewer_stack.selected_index = 1
        use_native.value = True

    status.value = (
        "<b style='color:#2e7d32'>"
        "CMB-0032 Patch F loaded.<br>"
        "Native Aladin viewer is now the primary viewer."
        "</b>"
    )

except Exception as exc:

    print("Display failed:")
    print(exc)

print("CMB-0032 PATCH F COMPLETE")


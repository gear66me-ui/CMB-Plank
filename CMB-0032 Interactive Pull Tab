print("CMB-0032 PATCH C")



# CMB-0032 PATCH D

# Replace the single HTML viewer with a viewer stack.

viewer_stack = widgets.Stack(
    selected_index=0,
    layout=widgets.Layout(width="100%", min_height="840px")
)

legacy_view = widgets.VBox([viewer])

native_view = widgets.VBox()

if IPYALADIN_AVAILABLE:
    native_view.children = (aladin,)
else:
    native_view.children = (
        widgets.HTML(
            "<b style='color:#b71c1c'>Native ipyaladin viewer unavailable.</b>"
        ),
    )

viewer_stack.children = (
    legacy_view,
    native_view,
)

use_native = widgets.Checkbox(
    value=False,
    description="Use Native Aladin Viewer",
    indent=False,
)

def toggle_native(change):

    if change["new"]:
        viewer_stack.selected_index = 1
    else:
        viewer_stack.selected_index = 0

use_native.observe(toggle_native, names="value")

viewer_panel = widgets.VBox([
    use_native,
    viewer_stack,
])

status.value = (
    "<b style='color:#1565c0'>"
    "CMB-0032 Patch D loaded. "
    "Viewer stack initialized."
    "</b>"
)

print("CMB-0032 PATCH D")

# CMB-0032 PATCH E
# Compatibility layer
# --------------------------------------------------------------------

print("CMB-0032 PATCH E")

# ---------- compatibility helpers ----------

def _exists(name):
    return name in globals()

if not _exists("STATE"):
    STATE = {}

if not _exists("status"):
    status = widgets.HTML()

if not _exists("viewer"):
    viewer = widgets.Output()

if not _exists("safe_float"):
    def safe_float(x):
        try:
            return float(x)
        except Exception:
            return np.nan

# ---------- optional hooks ----------

if _exists("refresh_coordinates"):

    _original_refresh_coordinates = refresh_coordinates

    def refresh_coordinates(*args, **kwargs):

        result = _original_refresh_coordinates(*args, **kwargs)

        if IPYALADIN_AVAILABLE:

            coord = STATE.get("coord")

            if coord is not None:

                try:
                    aladin.target = f"{coord.ra.deg} {coord.dec.deg}"
                except Exception:
                    pass

        return result

if _exists("inspect_button") and _exists("robust_inspect_galaxy"):

    inspect_button.on_click(
        robust_inspect_galaxy_cmb0032,
        remove=False
    )

print("Compatibility layer installed.")

# CMB-0032 PATCH F
# Final viewer replacement
# ============================================================================

print("CMB-0032 PATCH F")

# ------------------------------------------------------------------
# Replace the original viewer with the new viewer panel.
# ------------------------------------------------------------------

try:

    if "viewer" in globals():
        viewer = viewer_panel

except Exception as exc:


# CMB-0032 PATCH A
# Native ipyaladin initialization (non-destructive)
# ============================================================================

from ipyaladin import Aladin
from IPython.display import display

CMB0032_VERSION = "CMB-0032 PATCH A"

# ------------------------------------------------------------------
# Create the native Aladin widget
# ------------------------------------------------------------------

try:

    aladin = Aladin(
        target=str(target.value),
        survey=str(survey.value),
        fov=float(fov.value)
    )

    IPYALADIN_AVAILABLE = True

except Exception as exc:

    IPYALADIN_AVAILABLE = False
    aladin = None

    print("ipyaladin initialization failed")
    print(exc)

# ------------------------------------------------------------------
# Helper routines
# ------------------------------------------------------------------

def aladin_sync_from_controls():

    if not IPYALADIN_AVAILABLE:
        return

    try:
        aladin.target = str(target.value)
    except Exception:
        pass

    try:
        aladin.survey = str(survey.value)
    except Exception:
        pass

    try:
        aladin.fov = float(fov.value)
    except Exception:
        pass


def aladin_center_on(coord):

    if not IPYALADIN_AVAILABLE:
        return

    try:
        aladin.target = f"{coord.ra.deg} {coord.dec.deg}"
    except Exception:
        pass


# ------------------------------------------------------------------
# Synchronize whenever controls change
# ------------------------------------------------------------------

target.observe(lambda change: aladin_sync_from_controls(), names="value")
survey.observe(lambda change: aladin_sync_from_controls(), names="value")
fov.observe(lambda change: aladin_sync_from_controls(), names="value")

# ------------------------------------------------------------------
# Display below the existing interface.
# Nothing else changes yet.
# ------------------------------------------------------------------

if IPYALADIN_AVAILABLE:

    display(
        widgets.HTML(
            "<hr><h3>Native Aladin Viewer (Patch A Test)</h3>"
        )
    )

    display(aladin)

    print("Native Aladin initialized.")

else:

    print("Native Aladin unavailable.")




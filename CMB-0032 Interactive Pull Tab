def cmb0032_sync_native():

    if not IPYALADIN_AVAILABLE:
        return

    try:
        aladin.target = str(target.value)
    except Exception:
        pass

    try:
        aladin.survey = str(survey.value)
    except Exception:
        pass

    try:
        aladin.fov = float(fov.value)
    except Exception:
        pass


try:
    cmb0032_sync_native()
except Exception:
    pass


# ------------------------------------------------------------------

# CMB-0032 PATCH C

# Keep the native Aladin viewer synchronized with the
# current coordinates after every successful inspection.

_original_refresh_coordinates = refresh_coordinates


def refresh_coordinates_cmb0032(*args, **kwargs):

    result = _original_refresh_coordinates(*args, **kwargs)

    if not IPYALADIN_AVAILABLE:
        return result

    coord = STATE.get("coord")

    if coord is None:
        return result

    try:
        aladin.target = f"{coord.ra.deg} {coord.dec.deg}"
    except Exception:
        pass

    return result


refresh_coordinates = refresh_coordinates_cmb0032


